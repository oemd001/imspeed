import datetime

def parse_transaction(line):
    parts = line.strip().split(', ')
    date_time = datetime.datetime.strptime(parts[0], '%Y-%m-%d %H:%M:%S')
    return {
        'date_time': date_time,
        'crypto_type': parts[1],
        'amount': float(parts[2]),
        'transaction_id': parts[3]
    }

def initialize_crypto_dict():
    return {
        "additionalProp1": 0,
        "additionalProp2": 0,
        "additionalProp3": 0
    }

def calculate_analytics(transactions):
    total_spent = {}
    total_received = {}
    net_holdings = {}

    for transaction in transactions:
        crypto = transaction['crypto_type']
        amount = transaction['amount']

        if crypto not in total_spent:
            total_spent[crypto] = initialize_crypto_dict()
            total_received[crypto] = initialize_crypto_dict()
            net_holdings[crypto] = initialize_crypto_dict()

        # Update total spent and received
        if amount < 0:
            total_spent[crypto]["additionalProp1"] += (-amount)
        else:
            total_received[crypto]["additionalProp1"] += amount

        # Update net holdings
        net_holdings[crypto]["additionalProp1"] += amount

    return total_spent, total_received, net_holdings

def read_transactions_and_calculate(filename):
    transactions = []

    with open(filename, 'r') as file:
        for line in file:
            transaction = parse_transaction(line)
            transactions.append(transaction)

    total_spent, total_received, net_holdings = calculate_analytics(transactions)

    return total_spent, total_received, net_holdings

